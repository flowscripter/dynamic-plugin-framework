{
  "name": "@flowscripter/dynamic-plugin-framework",
  "version": "1.8.0",
  "description": "Dynamic plugin framework for Bun based on Javascript Modules and import() function",
  "keywords": [
    "bun",
    "dynamic",
    "framework",
    "import",
    "plugin"
  ],
  "homepage": "https://github.com/flowscripter/dynamic-plugin-framework#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flowscripter/dynamic-plugin-framework.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "bun": "./plugin.ts",
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "plugin.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build index.ts plugin.ts --outdir dist --target node && tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "semver": "^7.8.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/semver": "^7.7.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "typedocOptions": {
    "readme": "none",
    "exclude": [
      "tests/**"
    ]
  }
}
